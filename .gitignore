# Python が自動生成する一時ファイル（使い捨てなので履歴に入れない）
__pycache__/
*.pyc

# _trash は「削除の退避先」なので履歴管理の対象外にする
_trash/

# 記録（ユーザーの個人データ）。中身は人それぞれなので履歴には入れない。
#   records.csv      … 本番の記録（機能⑤）
#   records_*.csv    … お試し用・テスト用の記録（records_demo.csv / records_test.csv）
records.csv
records_*.csv

# 段階⑥ 可視化が作るグラフ画像（実行のたびに作り直せるので履歴に入れない）
*.png

# 段階⑦ Web版が作る個人データ・生成物（履歴に入れない）
#   profile.json … 最後に設定した目標（個人の体の情報）
#   static/      … ブラウザ表示用に作り直すグラフ画像の置き場
profile.json
static/

# 日本語フォント本体（数MBのバイナリ。履歴を重くしないため除外）。
#   無い環境では  python setup_font.py  で取得できる（ライセンス文も一緒に入る）。
assets/fonts/*.ttf
assets/fonts/*.otf
assets/fonts/*.txt

# --- 秘密情報・個人設定をGitHubに上げないための予防線（多重防御）---
# Claude Code がフォルダ内に作る個人設定（万一作られても履歴に入れない）
.claude/
# 将来APIキーなどを書くファイル（絶対に公開しない）
.env
.env.*
# 鍵ファイル全般
*.key
# 認証情報っぽいファイル全般
credentials*
